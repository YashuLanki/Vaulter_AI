# Vaulter AI — credentials template
# ------------------------------------------------------------------
# This file is safe to commit — it never holds a real secret, only
# placeholders. setup_wizard.py copies it to confidentials/.env (which
# IS gitignored) the first time someone runs the wizard on a machine
# that doesn't have one yet.
#
# FOR YASHU / IT — READ THIS ONCE:
# OUTLOOK_CLIENT_ID, OUTLOOK_TENANT_ID, ANTHROPIC_API_KEY,
# GOOGLE_PLACES_API_KEY, and GOOGLE_MAPS_API_KEY are organization-wide
# values (one Azure app registration, one set of API keys for the whole
# team) — NOT something each staff member should have to look up or
# paste in themselves. Fill in the real values below, ONCE, before
# distributing this repo/installer to staff, so every new teammate's
# .env starts pre-filled and the only thing left for them to do is sign
# into their OWN Microsoft account (python main.py auth) — see Priority 3
# in docs/MULTI_USER_TRANSITION.md for the full reasoning.
#
# Do NOT commit this file after filling in real values — copy it to
# confidentials/.env.template.filled (or wherever your distribution
# process pulls from) and keep that copy out of git, exactly like
# confidentials/.env itself already is.
# ------------------------------------------------------------------

# Shared Azure app registration for the Vaulter Email Pipeline (see
# README.md's Setup section for how to create this once for the team).
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=

# Only needed if your Azure app registration uses a client secret flow
# instead of the device-code flow this project uses by default — leave
# blank unless you know you need it.
OUTLOOK_CLIENT_SECRET=

# Shared Anthropic Console key — only screen_listings' Phase 3/4 calls
# use this; every other tool runs inside the user's own Claude Desktop
# conversation and needs no API key at all.
ANTHROPIC_API_KEY=

# Shared Google API keys (optional) — GOOGLE_PLACES_API_KEY powers
# run_google_places_export; GOOGLE_MAPS_API_KEY powers screen_listings'
# Phase 4 ground-truth verification. Both degrade gracefully if left
# blank (the features they power are simply skipped, everything else
# still works).
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=

# Auto-update channel (optional, defaults to "general" if left blank).
# Leave this blank/unset on every normal staff machine. Only set it to
# "canary" on a small number of designated machines (e.g. the
# maintainer's own) that should pick up a newly-published version
# immediately, before it's confirmed healthy and promoted to everyone
# else — see release.py and Priority 4 in docs/MULTI_USER_TRANSITION.md.
VAULTER_UPDATE_CHANNEL=
